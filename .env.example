# MentorMatch .env.example for Deployment
# =====================================================
# Copy this to .env and customize for your environment.
# Generate SECRET_KEY: python -c "from django.utils.crypto import get_random_string; print(get_random_string(50))"
# Add to .gitignore: .env
# Sections: Core | Database | Cache | Sessions | Security Headers
#
# PRODUCTION RECOMMENDATIONS:
# - DEBUG=False
# - Use HTTPS (SESSION_COOKIE_SECURE=True, CSRF_COOKIE_SECURE=True)
# - PostgreSQL + Redis
# - Allowed hosts: your domain
# - HSTS enabled

# ── Core ───────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-min-50-chars
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────────────────────────
# Default: SQLite (no config needed)
# For PostgreSQL:
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mentormatch
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Cache (Rate limiting, sessions) ────────────────────────────────────────────
# Default: LocMemCache
# For Redis (recommended for prod):
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://127.0.0.1:6379/1

# ── Session Security ───────────────────────────────────────────────────────────
SESSION_COOKIE_SECURE=True
SESSION_IDLE_TIMEOUT=1800  # seconds (30 min default)

# ── CSRF Security ──────────────────────────────────────────────────────────────
CSRF_COOKIE_SECURE=True

# ── Security Headers (HSTS for HTTPS sites) ────────────────────────────────────
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000  # 1 year
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

